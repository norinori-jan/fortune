# Flask settings
PORT=5000
FLASK_DEBUG=1
DB_PATH=/workspaces/fortune/backend/divinations.db

# When frontend/dist is missing, Flask redirects to this dev server.
FRONTEND_DEV_SERVER=http://127.0.0.1:5173

# Google Sheets export (optional)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_TAB_NAME=Divinations
# Set either GOOGLE_SERVICE_ACCOUNT_FILE or GOOGLE_SERVICE_ACCOUNT_JSON
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=
